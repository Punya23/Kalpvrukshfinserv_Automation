# ============================================
# Kalpvruksh Finserv AI Automation — Environment Variables
# ============================================
# Copy this file to `.env` and fill in your actual keys.

# --- LLM Provider ---
# For TESTING (Free): Use Groq
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter — pay-as-you-go fallback (no daily quota; used when Groq is rate-limited)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Speech-to-Text (Deepgram Nova-2, Hindi) ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- Text-to-Speech (AWS Polly Neural, Kajal hi-IN) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# --- Telephony (Exotel — India SIP, the live outbound provider) ---
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_CALLER_ID=your_exophone_number
EXOTEL_APP_ID=your_voicebot_applet_id
EXOTEL_SUBDOMAIN=api.exotel.com

# --- Google Sheets (for Lead Management) ---
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
LEADS_SHEET_ID=your_google_sheet_id_here
LEADS_SHEET_NAME=Hot Leads
NURTURE_SHEET_NAME=Nurture Pipeline
RENEWALS_SHEET_NAME=Renewals Tracker

# --- WhatsApp Business API (Interakt/Wati or Meta Direct) ---
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/
WHATSAPP_API_KEY=your_whatsapp_api_key_here
MANAGER_WHATSAPP_NUMBER=919876543210

# --- Manager Contact ---
MANAGER_NAME=Sanjeev Surana
MANAGER_PHONE=919876543210
MANAGER_EMAIL=sanjeev@kalpvrukshfinserv.com

# --- Campaign ---
# Max times a single number is dialed across all campaigns before it's skipped.
MAX_CALL_ATTEMPTS=3

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true
